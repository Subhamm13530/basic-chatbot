import random

def play_hangman():
    words = ["hangman", "amazing", "parking", "house", "classroom", "structure", "timetable", "python", "india", "device", "computer", "elephant", "mountain", "building", "language", "diamond", "hospital", "adventure", "children", "backpack", "festival", "keyboard", "notebook", "painting", "triangle", "umbrella", "velocity", "whisper", "yesterday", "umbrella", "splendid", "question", "sculpture", "navigator","ore"]
    secret_word = random.choice(words)
    guessed_letters = []
    incorrect_guesses = 0
    max_turns = 6

    print("Welcome to hangman!")
    print(f"The word has {len(secret_word)} letters.")

    while incorrect_guesses < max_turns:
        displayed_word = ""
        for letter in secret_word:
            if letter in guessed_letters:
                displayed_word += letter
            else:
                displayed_word += "_ "

        print("\nWord: " + displayed_word.strip())
        print(f"Incorrect guesses left: {max_turns - incorrect_guesses}")
        print(f"Guessed letters: {', '.join(sorted(guessed_letters)) if guessed_letters else 'None'}")

        if "_" not in displayed_word:
            print("\n🎉 Congratulations! You guessed the word!")
            break

        guess = input("Guess a letter: ").lower().strip()
        if len(guess) != 1 or not guess.isalpha():
            print("Please enter a single valid letter.")
            continue

        if guess in guessed_letters:
            print("You already guessed that letter. Try another one!")
            continue

        guessed_letters.append(guess)

        if guess in secret_word:
            print(f"Good job! '{guess}' is in the word.")
        else:
            print(f"Sorry, '{guess}' is not in the word.")
            incorrect_guesses += 1

    if incorrect_guesses == max_turns:
        print("\n💥 Game Over! You ran out of guesses.")
        print(f"The word was: {secret_word}")


if __name__ == "__main__":
    play_hangman()